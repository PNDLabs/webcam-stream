{
  "camera": {
    "device": "/dev/video2",
    "resolution": "1280x720",
    "framerate": 1,
    "rotation": 0
  },
  "recording": {
    "enabled": true,
    "segmentDuration": 1800,
    "retentionDays": 2,
    "outputDir": "./recordings",
    "eventDetection": {
      "enabled": false,
      "motionEnabled": true,
      "soundEnabled": true,
      "motionThreshold": 0.12,
      "motionSampleIntervalMs": 500,
      "motionMinDurationMs": 800,
      "motionEndAfterMs": 1200,
      "soundSilenceDb": -40,
      "soundSilenceDurationSec": 0.6
    }
  },
  "watermark": {
    "enabled": true,
    "format": "%Y-%m-%d %H:%M:%S",
    "position": "bottom-right",
    "fontSize": 24,
    "fontColor": "white",
    "backgroundColor": "black@0.5"
  },
  "audio": {
    "enabled": true,
    "device": "hw:1,0"
  },
  "server": {
    "port": 8081
  }
}