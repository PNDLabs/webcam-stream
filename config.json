{
  "camera": {
    "device": "/dev/video2",
    "resolution": "1280x720",
    "framerate": 1,
    "rotation": 0
  },
  "recording": {
    "enabled": true,
    "segmentDuration": 1800,
    "retentionDays": 2,
    "outputDir": "./recordings"
  },
  "watermark": {
    "enabled": true,
    "format": "%Y-%m-%d %H:%M:%S",
    "position": "bottom-right",
    "fontSize": 24,
    "fontColor": "white",
    "backgroundColor": "black@0.5"
  },
  "server": {
    "port": 8081
  }
}